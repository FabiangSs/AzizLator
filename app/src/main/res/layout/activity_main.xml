<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0F"
    android:padding="16dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AZIZLATOR"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#00D4FF" />

            <TextView
                android:id="@+id/tv_device_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📱 Detecting..."
                android:textSize="12sp"
                android:textColor="#888888" />

            <TextView
                android:id="@+id/tv_performance_mode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡ Mode: AUTO"
                android:textSize="12sp"
                android:textColor="#00FF88" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_preferences"
            android:background="@android:color/transparent"
            android:tint="#00D4FF" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1A1A2E"
        android:layout_marginVertical="12dp" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🗂️ Containers"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <!-- Containers List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_containers"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- New Container Button -->
    <Button
        android:id="@+id/btn_new_container"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="＋ New Container"
        android:textSize="16sp"
        android:backgroundTint="#00D4FF"
        android:textColor="#000000"
        android:layout_marginTop="12dp" />

</LinearLayout>
